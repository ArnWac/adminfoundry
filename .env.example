# adminfoundry — example environment file.
# Copy to `.env` and edit; never commit a real `.env`.

# --- required ----------------------------------------------------------
ADMINFOUNDRY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adminfoundry
# Generate via: openssl rand -hex 32
ADMINFOUNDRY_SECRET_KEY=replace-with-32+-random-bytes


# --- app ---------------------------------------------------------------
ADMINFOUNDRY_APP_TITLE=adminfoundry
ADMINFOUNDRY_DEBUG=false


# --- route prefixes ---------------------------------------------------
ADMINFOUNDRY_AUTH_API_PREFIX=/api/v1/auth
ADMINFOUNDRY_ADMIN_API_PREFIX=/api/v1/admin
ADMINFOUNDRY_ROOT_API_PREFIX=/api/v1/root
ADMINFOUNDRY_ADMIN_UI_PATH=/admin


# --- auth / tokens -----------------------------------------------------
ADMINFOUNDRY_JWT_ALGORITHM=HS256
ADMINFOUNDRY_ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMINFOUNDRY_PASSWORD_MIN_LENGTH=8


# --- feature toggles ---------------------------------------------------
ADMINFOUNDRY_ENABLE_BUILTIN_UI=true
ADMINFOUNDRY_ENABLE_BUILTIN_ADMINS=true
ADMINFOUNDRY_ENABLE_MULTI_TENANT=true


# --- tenancy -----------------------------------------------------------
# header | subdomain
ADMINFOUNDRY_TENANT_RESOLUTION=header
ADMINFOUNDRY_TENANT_HEADER_NAME=X-Tenant-Slug


# --- locale defaults --------------------------------------------------
ADMINFOUNDRY_DEFAULT_LANGUAGE=en
ADMINFOUNDRY_DEFAULT_DATE_FORMAT=locale
ADMINFOUNDRY_DEFAULT_DATE_PATTERN=%Y-%m-%d %H:%M
ADMINFOUNDRY_DEFAULT_SHOW_TIMEZONE=false


# --- database pool ----------------------------------------------------
ADMINFOUNDRY_DB_POOL_SIZE=10
ADMINFOUNDRY_DB_MAX_OVERFLOW=20
ADMINFOUNDRY_DB_POOL_PRE_PING=true


# --- logging ----------------------------------------------------------
# CRITICAL / ERROR / WARNING / INFO / DEBUG / NOTSET
ADMINFOUNDRY_LOG_LEVEL=INFO
# Set true in production for structured JSON logs.
ADMINFOUNDRY_LOG_JSON=false


# --- CORS (only used if origins are set) ------------------------------
# Comma-separated list. Empty = no CORS middleware installed.
ADMINFOUNDRY_CORS_ORIGINS=
ADMINFOUNDRY_CORS_ALLOW_CREDENTIALS=false
ADMINFOUNDRY_CORS_ALLOW_METHODS=GET,POST,PATCH,DELETE,OPTIONS
ADMINFOUNDRY_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Tenant-Slug


# --- security headers -------------------------------------------------
ADMINFOUNDRY_SECURITY_HEADERS_ENABLED=true


# --- CLI helper (optional) --------------------------------------------
# Lets `adminfoundry permissions sync` discover your FastAPI app without
# explicit --app argument.
# ADMINFOUNDRY_APP=app:app
